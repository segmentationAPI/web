---
interface Props {
  title?: string;
}

const { title = "Note" } = Astro.props;
---

<aside class="border-secondary/30 bg-secondary/8 my-8 rounded-2xl border px-5 py-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)]">
  <p class="text-secondary font-mono text-[0.68rem] tracking-[0.16em] uppercase">{title}</p>
  <div class="mt-2 text-sm leading-[1.7] text-[color-mix(in_srgb,var(--foreground)_84%,transparent)] [&_p:last-child]:mb-0">
    <slot />
  </div>
</aside>
