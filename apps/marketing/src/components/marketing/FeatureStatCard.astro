---
interface Props {
  title: string;
  description: string;
  kicker: string;
  stat: string;
  icon: any;
}

const { title, description, kicker, stat, icon: Icon } = Astro.props;
---

<article class="border-primary/30 relative rounded-[1.6rem] border bg-[linear-gradient(145deg,rgba(255,255,255,0.03),transparent_44%),linear-gradient(180deg,rgba(255,112,63,0.14),rgba(255,112,63,0.04)_40%,rgba(8,10,17,0.86))]">
  <div class="p-5">
    <div class="flex items-start justify-between gap-4">
      <p class="font-mono text-[0.68rem] tracking-[0.18em] text-[#ffd1ba] uppercase">{kicker}</p>
      <div class="border-secondary/40 text-secondary inline-flex h-10 w-10 items-center justify-center rounded-[0.9rem] border bg-[rgba(8,11,17,0.52)]">
        <Icon class="h-5 w-5" aria-hidden="true" />
      </div>
    </div>
    <p class="font-display mt-4 text-[clamp(1.45rem,3vw,2.25rem)] leading-[0.98] tracking-[-0.05em]">
      {stat}
    </p>
    <h3 class="font-display mt-3 text-xl leading-[1.05]">{title}</h3>
    <p class="text-muted-foreground mt-3 text-[0.92rem] leading-[1.65]">{description}</p>
  </div>
</article>
