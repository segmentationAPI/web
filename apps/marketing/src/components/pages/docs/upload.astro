---
import Table from "@/components/table/Table.astro";
import TableBody from "@/components/table/TableBody.astro";
import TableCell from "@/components/table/TableCell.astro";
import TableHead from "@/components/table/TableHead.astro";
import TableHeader from "@/components/table/TableHeader.astro";
import TableRow from "@/components/table/TableRow.astro";
import DocsCodeBlock from "@/components/docs/DocsCodeBlock.astro";
import DocsPageNav from "@/components/docs/DocsPageNav.astro";
import DocsPageHeader from "@/components/docs/DocsPageHeader.astro";
import DocsCallout from "@/components/docs/DocsCallout.astro";
import DocsH2 from "@/components/docs/DocsH2.astro";
import DocsH3 from "@/components/docs/DocsH3.astro";
import DocsInlineCode from "@/components/docs/DocsInlineCode.astro";
import DocsProse from "@/components/docs/DocsProse.astro";
import DocsSection from "@/components/docs/DocsSection.astro";

const presignRequest = `curl -X POST \\
  https://api.segmentationapi.com/v1/uploads/presign \\
  -H "Content-Type: application/json" \\
  -H "x-api-key: YOUR_SEGMENTATION_API_KEY" \\
  -d '{
    "contentType": "image/png"
  }'`;

const presignResponse = `{
  "uploadUrl": "https://segmentation-assets-prod.s3.us-east-2.amazonaws.com/inputs/acct_demo_123/0000_a1b2c3d4?X-Amz-Algorithm=AWS4-HMAC-SHA256&X-Amz-Expires=300&X-Amz-Signature=example",
  "taskId": "0000_a1b2c3d4",
  "bucket": "segmentation-assets-prod",
  "expiresIn": 300
}`;

const uploadFile = `curl -X PUT "https://s3.amazonaws.com/...signed-url..." \\
  -H "Content-Type: image/png" \\
  --data-binary "@frame-0001.png"`;

---

      <DocsPageHeader
        current="Upload Flow"
        title="Upload Flow">
            Media uploads use presigned S3 URLs. Request one with 
            <code class="text-secondary font-mono text-sm">POST /v1/uploads/presign</code>,
            upload directly to S3, then use the returned 
            <code class="text-secondary font-mono text-sm">taskId</code> when creating
            segmentation jobs.
</DocsPageHeader>

      <DocsSection>
        <DocsProse>
          <DocsH2>Step 1 — Request a Presigned URL</DocsH2>
          <p>
            Send a POST request with the <DocsInlineCode>contentType</DocsInlineCode> of the file
            you want to upload. The API returns a signed URL valid for 5 minutes, along with the 
            <DocsInlineCode>taskId</DocsInlineCode> that identifies this upload in subsequent job
            requests.
          </p>

          <DocsCodeBlock code={presignRequest} label="Request" />

          <DocsH3>Response</DocsH3>
          <DocsCodeBlock code={presignResponse} label="200 OK" />

          <Table class="my-4">
            <TableHeader>
              <TableRow class="border-border/30 hover:bg-transparent">
                <TableHead class="font-mono text-[0.68rem] tracking-widest uppercase">
                  Field
                </TableHead>
                <TableHead class="font-mono text-[0.68rem] tracking-widest uppercase">
                  Type
                </TableHead>
                <TableHead class="font-mono text-[0.68rem] tracking-widest uppercase">
                  Description
                </TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              <TableRow class="border-border/15">
                <TableCell>
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    uploadUrl
                  </code>
                </TableCell>
                <TableCell>
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    string
                  </code>
                </TableCell>
                <TableCell class="text-muted-foreground">
                  Presigned S3 PUT URL — expires after 
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    expiresIn
                  </code> 
                  seconds
                </TableCell>
              </TableRow>
              <TableRow class="border-border/15">
                <TableCell>
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    taskId
                  </code>
                </TableCell>
                <TableCell>
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    string
                  </code>
                </TableCell>
                <TableCell class="text-muted-foreground">
                  Unique identifier for this upload; use in 
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    POST /v1/jobs
                  </code>
                </TableCell>
              </TableRow>
              <TableRow class="border-border/15">
                <TableCell>
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    bucket
                  </code>
                </TableCell>
                <TableCell>
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    string
                  </code>
                </TableCell>
                <TableCell class="text-muted-foreground">
                  S3 bucket name (informational)
                </TableCell>
              </TableRow>
              <TableRow class="border-border/15">
                <TableCell>
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    expiresIn
                  </code>
                </TableCell>
                <TableCell>
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    number
                  </code>
                </TableCell>
                <TableCell class="text-muted-foreground">
                  URL validity in seconds (default 300)
                </TableCell>
              </TableRow>
            </TableBody>
          </Table>
        </DocsProse>
      </DocsSection>

      <DocsSection>
        <DocsProse>
          <DocsH2>Step 2 — Upload File to S3</DocsH2>
          <p>
            Use the <DocsInlineCode>uploadUrl</DocsInlineCode> from the presign response to PUT the
            raw file bytes directly to S3. Set the <DocsInlineCode>Content-Type</DocsInlineCode> 
            header to match the <DocsInlineCode>contentType</DocsInlineCode> you specified in the
            presign request.
          </p>

          <DocsCodeBlock code={uploadFile} label="PUT to S3" />

          <DocsCallout>
            <strong>Content-Type must match.</strong> The Content-Type in your PUT request must
            match the contentType from the presign request, or S3 will reject the upload with a 
            <DocsInlineCode>403</DocsInlineCode>.
          </DocsCallout>
        </DocsProse>
      </DocsSection>

      <DocsSection>
        <DocsProse>
          <DocsH2>Supported Formats</DocsH2>
          <Table class="my-4">
            <TableHeader>
              <TableRow class="border-border/30 hover:bg-transparent">
                <TableHead class="font-mono text-[0.68rem] tracking-widest uppercase">
                  Type
                </TableHead>
                <TableHead class="font-mono text-[0.68rem] tracking-widest uppercase">
                  Supported Formats
                </TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              <TableRow class="border-border/15">
                <TableCell class="text-muted-foreground">Images</TableCell>
                <TableCell>
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    image/png
                  </code>
                  {", "}
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    image/jpeg
                  </code>
                  {", "}
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    image/webp
                  </code>
                </TableCell>
              </TableRow>
              <TableRow class="border-border/15">
                <TableCell class="text-muted-foreground">Video</TableCell>
                <TableCell>
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    video/mp4
                  </code>
                  {", "}
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    video/quicktime
                  </code>
                  {", "}
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    video/webm
                  </code>
                  {", "}
                  <code class="bg-secondary/10 text-secondary rounded px-1.5 py-0.5 font-mono text-xs">
                    video/x-matroska
                  </code>
                </TableCell>
              </TableRow>
            </TableBody>
          </Table>

          <DocsCallout>
            Any <DocsInlineCode>image/*</DocsInlineCode> or <DocsInlineCode>video/*</DocsInlineCode> 
            MIME type is accepted — the types above are the common, well-tested ones. The 
            <DocsInlineCode>Content-Type</DocsInlineCode> you presign with is what your PUT must
            send.
          </DocsCallout>
        </DocsProse>
      </DocsSection>

      <DocsPageNav
        prev={{ href: "/docs/authentication", title: "Authentication" }}
        next={{ href: "/docs/jobs", title: "Jobs" }}
      />
