---
interface Props { method: "GET" | "POST" | "PUT"; class?: string }
const { method, class: className } = Astro.props;
---
<span class:list={["inline-flex h-auto w-fit items-center justify-center rounded-[0.35rem] border px-[0.55rem] py-[0.2rem] font-mono text-[0.65rem] font-bold tracking-[0.08em] uppercase", method === "GET" && "border-[#39d5c94d] bg-[#39d5c926] text-secondary", method === "POST" && "border-primary/30 bg-primary/15 text-primary", method === "PUT" && "border-[#f2b77a4d] bg-[#f2b77a26] text-[#f2b77a]", className]}>{method}</span>
