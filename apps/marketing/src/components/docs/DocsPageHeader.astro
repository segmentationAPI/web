---
interface Props {
  title: string;
  current: string;
  eyebrow?: string;
}

const { title, current, eyebrow } = Astro.props;
---

<nav aria-label="Breadcrumb" class="reveal text-muted-foreground mb-8 flex items-center gap-1.5 font-mono text-[0.68rem] tracking-[0.12em] uppercase">
  <a href="/docs" class="hover:text-foreground transition-colors">Docs</a>
  <span aria-hidden="true" class="text-muted-foreground/40">/</span>
  <span aria-current="page">{current}</span>
</nav>
<header class="reveal">
  <h1 class="font-display mb-3 text-[1.75rem] leading-[1.15] font-bold tracking-[-0.025em] sm:text-[2.75rem]">
    {title}
  </h1>
  <p class="text-muted-foreground mb-10 text-[1.05rem] leading-[1.7]"><slot /></p>
  {eyebrow && <div class="text-muted-foreground -mt-2 mb-8 font-mono text-[0.75rem] tracking-[0.16em] uppercase">{eyebrow}</div>}
</header>
