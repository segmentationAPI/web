---
import { render, type CollectionEntry } from "astro:content";
import { ArrowLeft, CalendarDays } from "@lucide/astro";

import BlogCallout from "@/components/BlogCallout.astro";
import BlogCode from "@/components/BlogCode.astro";
import BlogImage from "@/components/BlogImage.astro";
import BlogLink from "@/components/BlogLink.astro";
import BlogTable from "@/components/BlogTable.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatBlogDate, getPublishedBlogPosts } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | SegmentationAPI Blog`}
  description={post.data.description}
  pathname={`/blog/${post.id}`}
  openGraphType="article"
  publishedAt={post.data.publishedAt}
  updatedAt={post.data.updatedAt}
  tags={post.data.tags}
>
  <main class="mx-auto w-full max-w-4xl px-4 pt-8 pb-24 sm:px-8 sm:pt-12">
    <a
      href="/blog"
      class="reveal text-muted-foreground hover:text-foreground mb-8 inline-flex items-center gap-2 font-mono text-[0.7rem] tracking-[0.14em] uppercase transition-colors"
    >
      <ArrowLeft class="h-3.5 w-3.5" aria-hidden="true" />
      Back to blog
    </a>

    <article
      class="reveal border-primary/20 bg-card/80 rounded-[2rem] border px-5 py-7 shadow-[0_24px_70px_rgba(5,7,12,0.5),inset_0_1px_0_rgba(255,255,255,0.04)] sm:px-8 sm:py-10"
      style="animation-delay: 140ms"
    >
      <header class="border-primary/18 mb-8 flex flex-col gap-4 border-b pb-8">
        <span class="border-primary/75 bg-primary/18 inline-flex w-fit items-center gap-[0.45rem] rounded-full border px-[0.8rem] py-[0.45rem] font-mono text-[0.65rem] tracking-[0.16em] uppercase">
          <CalendarDays class="h-4 w-4" aria-hidden="true" />
          {formatBlogDate(post.data.publishedAt)}
        </span>
        <p class="text-muted-foreground max-w-2xl text-base leading-[1.75]">
          {post.data.description}
        </p>
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="border-primary/25 bg-primary/10 text-muted-foreground rounded-full border px-2.5 py-1 font-mono text-[0.62rem] tracking-[0.12em] uppercase">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <div class="blog-mdx text-[0.98rem] sm:text-[1.02rem]">
        <Content
          components={{
            Image: BlogImage,
            Callout: BlogCallout,
            a: BlogLink,
            code: BlogCode,
            table: BlogTable,
          }}
        />
      </div>
    </article>
  </main>
</BaseLayout>
