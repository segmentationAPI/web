{
  "name": "@segmentationapi/sdk",
  "version": "0.6.1",
  "description": "Official JavaScript SDK for Segmentation API.",
  "keywords": [
    "api",
    "sdk",
    "segmentation"
  ],
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/segmentationAPI/sdk"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "pnpm run build:release",
    "clean": "rm -rf dist coverage",
    "build:release": "tsup",
    "typecheck": "tsc --noEmit",
    "check-types": "pnpm run typecheck",
    "lint": "pnpm exec oxlint --type-aware --type-check .",
    "lint:fix": "pnpm exec oxlint --type-aware --type-check --fix .",
    "format": "pnpm exec oxfmt --write .",
    "format:check": "pnpm exec oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build:release && pnpm run test && pnpm run typecheck"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.28.1"
}
