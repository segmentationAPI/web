{
  "name": "@segmentation/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "lint": "pnpm exec oxlint --type-aware --type-check .",
    "lint:fix": "pnpm exec oxlint --type-aware --type-check --fix .",
    "format": "pnpm exec oxfmt --write .",
    "format:check": "pnpm exec oxfmt --check .",
    "check-types": "pnpm exec tsc --noEmit -p tsconfig.json",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@segmentation/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@segmentation/config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}
